{
  "name": "Jannowitz Records",
  "workspaces": [
    "studio",
    "frontend"
  ],
  "scripts": {
    "dev": "pnpm-run-all --parallel --print-label dev:*",
    "dev:next": "pnpm run dev --workspace=frontend",
    "dev:studio": "pnpm run dev --workspace=studio",
    "format": "prettier --cache --write .",
    "import-sample-data": "cd studio && sanity dataset import sample-data.tar.gz --replace",
    "lint": "pnpm run lint --workspace=frontend",
    "type-check": "pnpm run type-check --workspaces"
  }
}
